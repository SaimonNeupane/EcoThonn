# Copy this file to .env and fill in your real values.
# The .env file is gitignored — never commit secrets.

# MongoDB connection string
# Atlas example:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Local example:  mongodb://localhost:27017
MONGODB_URL=mongodb://localhost:27017

# Name of the database
DATABASE_NAME=ecothonn_db
